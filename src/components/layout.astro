---
import '/src/style.css';
import SEO from '/src/components/seo.astro';
import Footer from '/src/components/footer.astro';
import Wall from '/src/components/wall.astro';
import MiniArch from '/src/components/mini-arch.astro';

const { title, description, content } = Astro.props;

import { getCollection } from 'astro:content';
const allContent = await getCollection('content');
const sortedContent = allContent.sort((a, b) => a.data.order - b.data.order);

const currentIndex = sortedContent.findIndex((post) => {
  const postPath = `/${post.id}`;
  return content.url === postPath || content.url === `${postPath}/`;
});

const prevPost = currentIndex > 0 ? sortedContent[currentIndex - 1] : null;
const nextPost = currentIndex < sortedContent.length - 1 ? sortedContent[currentIndex + 1] : null;

const skyPosition = 100 - (currentIndex * 10)

const Center = content.projectUrl ? 'a' : 'div';

const slotContent = await Astro.slots.render('default');
const hasContent = !!slotContent?.trim();
---

<html lang="en">
<!-- 
